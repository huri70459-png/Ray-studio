{
  "name": "@ray-studio/studio",
  "version": "0.1.0",
  "private": true,
  "description": "Ray Studio desktop shell (Electron + React)",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint src electron-main --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src electron-main --ext .ts,.tsx,.js,.jsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "clean": "rimraf dist dist-electron"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.408.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.3.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.39",
    "rimraf": "^6.0.0",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.8.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
